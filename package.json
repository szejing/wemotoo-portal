{
	"name": "wemotoo-portal",
	"private": true,
	"type": "module",
	"scripts": {
		"build:dev": "NODE_OPTIONS=--max-old-space-size=8192 nuxt build --dotenv .env.dev",
		"build:prod": "NODE_OPTIONS=--max-old-space-size=8192 nuxt build --dotenv .env.prod",
		"build:prod:docker": "node node_modules/nuxt/bin/nuxt.mjs build --dotenv .env.prod",
		"clean": "rm -rf node_modules && rm -rf dist && rm -rf .nuxt && rm -rf bun.lock",
		"rebuild": "bun run clean && bun install && bun update yeppi-common",
		"start:local": "nuxt dev --dotenv .env.local",
		"start:dev": "nuxt dev --dotenv .env.dev",
		"start:prod": "nuxt dev --dotenv .env.prod",
		"generate": "NODE_OPTIONS=--max-old-space-size=8192 nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"test": "bun test",
		"test:vitest": "vitest",
		"test:vitest:run": "vitest run",
		"test:repository": "bun test app/repository",
		"typecheck": "nuxt typecheck",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
		"docker:prod": "docker-compose -f docker-compose.prod.yml up --build",
		"docker:build:dev": "docker buildx build --platform linux/arm64 -t wemotoo:dev .",
		"docker:build:prod": "docker buildx build --platform linux/amd64 -t wemotoo:prod ."
	},
	"dependencies": {
		"@nuxt/eslint": "^1.16.0",
		"@nuxt/image": "2.0.0",
		"@nuxt/ui": "^4.8.2",
		"@nuxtjs/i18n": "^10.4.0",
		"@pinia/nuxt": "^0.11.3",
		"@types/uuid": "^11.0.0",
		"@unovis/ts": "^1.6.5",
		"@unovis/vue": "^1.6.5",
		"@vee-validate/zod": "^4.15.1",
		"@vueup/vue-quill": "^1.5.3",
		"autoprefixer": "^10.5.0",
		"date-fns": "^4.4.0",
		"heic2any": "^0.0.4",
		"intl": "^1.2.5",
		"malaysia-postcodes": "^2.7.3",
		"nuxt": "^4.4.8",
		"pinia": "^3.0.4",
		"postcss": "^8.5.15",
		"vee-validate": "^4.15.1",
		"vue": "latest",
		"vue-router": "latest",
		"yeppi-common": "git+https://github.com/szejing/yeppi-common.git",
		"zod": "^4.0.17"
	},
	"devDependencies": {
		"@headlessui/vue": "1.7.23",
		"@iconify-json/heroicons": "^1.2.3",
		"@iconify-json/ic": "^1.2.4",
		"@iconify-json/lucide": "^1.2.111",
		"@iconify-json/material-symbols": "^1.2.77",
		"@iconify-json/material-symbols-light": "^1.2.77",
		"@iconify-json/mdi": "^1.2.3",
		"@iconify-json/octicon": "^1.2.28",
		"@iconify-json/ri": "^1.2.10",
		"@iconify-json/simple-icons": "^1.2.86",
		"@iconify-json/tabler": "^1.2.35",
		"@nuxt/devtools": "^3.2.4",
		"@nuxt/eslint-config": "^1.16.0",
		"@nuxt/test-utils": "4.0.3",
		"@nuxtjs/eslint-config-typescript": "12.1.0",
		"@nuxtjs/eslint-module": "4.1.0",
		"@nuxtjs/google-fonts": "^3.2.0",
		"@stylistic/eslint-plugin-ts": "^4.4.1",
		"@types/bun": "latest",
		"@vue/test-utils": "^2.4.11",
		"@vueuse/core": "^14.3.0",
		"@vueuse/motion": "3.0.3",
		"@vueuse/nuxt": "^14.3.0",
		"eslint": "^10.4.1",
		"happy-dom": "^20.10.2",
		"tailwindcss": "4.3.0",
		"vitest": "^4.1.8",
		"vue-tsc": "^3.3.7"
	},
	"module": "index.ts",
	"peerDependencies": {
		"typescript": "^6.0.3"
	}
}
